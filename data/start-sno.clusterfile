account:
  pullSecret: data/secrets/pull-secret.json

cluster:
  name: <cluster-name>
  version: 4.21.0
  platform: none
  sshKeys:
    - data/secrets/id_rsa.pub

network:
  domain: <base-domain>
  nameservers:
    - <dns-server>
  primary:
    gateway: <gateway>
    subnet: <subnet-cidr>

hosts:
  <fqdn>:
    role: control
    storage:
      os:
        deviceName: <device-path>
    bmc:
      vendor: <bmc-vendor>
      address: <bmc-address>
      username: <bmc-username>
      password: data/secrets/bmc-password.txt
    network:
      interfaces:
        - name: eth0
          macAddress: <mac>
      primary:
        address: <host-ip>
        ports: [eth0]
